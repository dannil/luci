{
	"luci-app-apk": {
		"description": "Grant access to apk management",
		"read": {
			"cgi-io": [ "exec" ],
			"file": {
				"/usr/libexec/apk-call list-installed": [ "exec" ],
				"/usr/libexec/apk-call list-available": [ "exec" ],
				"/etc/apk/*": [ "read" ]
			},
			"ubus": {
				"luci": [ "getMountPoints" ]
			}
		},
		"write": {
			"file": {
				"/usr/libexec/apk-call install *": [ "exec" ],
				"/usr/libexec/apk-call remove *": [ "exec" ],
				"/usr/libexec/apk-call update *": [ "exec" ],
				"/etc/apk/*": [ "write" ],
				"/tmp/upload.ipk": [ "write" ]
			}
		}
	}
}
